# Database (MariaDB externo)
DATABASE_URL="mysql://user:password@host:3306/qts"

# LDAP (somente leitura)
LDAP_URL="ldap://directory.example.local:389"
LDAP_BIND_DN="uid=readonly-service,ou=services,dc=example,dc=local"
LDAP_BIND_PASSWORD="change-me"
LDAP_BASE_DN="dc=example,dc=local"
LDAP_UID_ATTRIBUTE="uid"
LDAP_SARAM_ATTRIBUTE="employeeNumber"
LDAP_MAIL_ATTRIBUTE="mail"
LDAP_NAME_ATTRIBUTE="cn"
LDAP_OM_ATTRIBUTE="organizationUnit"
LDAP_RANK_ATTRIBUTE="rank"
LDAP_WARNAME_ATTRIBUTE="displayName"
LDAP_TIMEOUT_MS="10000"

# App/Auth
NEXTAUTH_SECRET="change-me-min-32-chars"
NEXTAUTH_URL="http://localhost:3000"
NEXT_PUBLIC_API_URL="http://localhost:4000"
# Origem pública do frontend (usada pelo /trust para o retorno após aceite do certificado)
FRONTEND_URL="http://localhost:3000"

# Runtime
NODE_ENV="production"
TEST_MODE="false"

# Network bind
# Endereço em que a API Node escuta dentro do container/processo
BIND_HOST="0.0.0.0"
# Endereço de bind da porta publicada no host Docker
API_BIND_IP="0.0.0.0"

# Seed
INITIAL_USER_CPF="00000000000"
